{
	"manifest_version": 2,
	"name": "Twitter to Nitter",
	"version": "1.3",
	"description": "Redirects Twitter/X to Nitter for a private, ad-free experience.",
	"permissions": [
		"webNavigation",
		"*://twitter.com/*",
		"*://x.com/*"
	],
	"browser_specific_settings": {
	"gecko": {
	"id": "my-cool-extension@lol.dongs",
		"data_collection_permissions": {
	      "required": ["none"]
			}
		}
	
	},

	"background": {
		"scripts": ["background.js"],
		"persistent": false
	}
}
